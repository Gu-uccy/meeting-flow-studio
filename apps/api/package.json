{
  "name": "@meeting-flow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --import tsx --watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file-if-exists=.env dist/apps/api/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:postgres": "vitest run src/__tests__/postgresIntegration.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/websocket": "^11.2.0",
    "@meeting-flow/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "embedded-postgres": "18.4.0-beta.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
