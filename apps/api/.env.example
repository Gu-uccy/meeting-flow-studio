PORT=8787
HOST=127.0.0.1
JWT_SECRET=replace-with-a-long-random-secret

# Unified OpenAI-compatible AI service (chat + embeddings share one key).
# Also accepted: OPENAI_API_KEY as an alias for AI_API_KEY.
AI_API_KEY=
# OPENAI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini
AI_EMBEDDING_MODEL=text-embedding-3-small
# Optional: overrides JWT_SECRET as the encryption secret for user-provided model API keys.
AI_KEY_ENCRYPTION_SECRET=

# Optional: vector knowledge chunking controls for long meeting memories and notes.
KNOWLEDGE_CHUNK_SIZE=480
KNOWLEDGE_CHUNK_OVERLAP=96

# Database (default: SQLite file under apps/api/data/)
# DB_DRIVER=sqlite
# SQLITE_PATH=./data/meetings.db
# For PostgreSQL:
# DB_DRIVER=postgres
# DATABASE_URL=postgresql://user:pass@localhost:5432/meeting_flow
# DB_SSL=true
# DB_POOL_MAX=10

# Google Calendar / Meet OAuth.
# Create a Web application OAuth client in Google Cloud Console and add the redirect URI below.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/api/integrations/google/callback

# Feishu / Lark Calendar OAuth.
# Create an app in Feishu Open Platform, enable Calendar permissions, and add this redirect URI.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_REDIRECT_URI=http://127.0.0.1:8787/api/integrations/feishu/callback
FEISHU_CALENDAR_ID=primary
FEISHU_OAUTH_SCOPES="calendar:calendar calendar:calendar.event:create vc:meeting.meetingevent:read vc:record:readonly minutes:minutes.transcript:export"
FEISHU_VERIFICATION_TOKEN=
# FEISHU_ENCRYPT_KEY=
