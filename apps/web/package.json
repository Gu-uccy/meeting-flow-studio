{
  "name": "@meeting-flow/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/e2e-workbench-flow.mjs",
    "test:watch": "vitest",
    "css:consolidate": "python scripts/consolidate-css.py",
    "css:purge": "python scripts/purge-unused-css.py",
    "css:restore": "python scripts/restore-critical-css.py"
  },
  "dependencies": {
    "@meeting-flow/shared": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "reactflow": "^11.11.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.5",
    "vitest": "^3.0.5"
  }
}